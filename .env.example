# Local sandbox API URL for development: SANDBOX_API_URL=http://127.0.0.1:8080
# Remember to run 'kubectl -n agent-sandbox-application port-forward svc/sandbox-router-svc 8080:8080'
# before running the application
SANDBOX_API_URL=http://sandbox-router-svc.agent-sandbox-application.svc.cluster.local:8080

# Database — choose ONE of the two options below:

# Option 1: Cloud SQL Python Connector (production / GKE)
# Uses google.cloud.sql.connector — no direct IP or SSL config needed
CLOUD_SQL_CONNECTION_NAME=your-cloud-sql-connection-name
DB_USER=postgres
DB_PASS=your-db-password
DB_NAME=postgres

# Authentication
JWT_SECRET=your-secret-key-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com